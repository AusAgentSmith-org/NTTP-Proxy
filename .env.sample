INDEXARR_URL=https://nzb.indexarr.net
INDEXARR_API_KEY=your-indexarr-api-key

# Upstream NNTP provider
NNTP_HOST=news.example.com
NNTP_PORT=563
NNTP_USER=your-username
NNTP_PASS=your-password
NNTP_CONNECTIONS=15

# App-server tokens — use strong random values in production
ADMIN_TOKEN=change-me
PROXY_TOKEN=change-me

# Bootstrap user created on first start if DB is empty
BOOTSTRAP_USER=admin
BOOTSTRAP_PASS=change-me
BOOTSTRAP_MAX_CONNECTIONS=8
